{
  "name": "iptv-player",
  "version": "1.0.0",
  "description": "Modern IPTV Player for macOS",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.iptv.player",
    "productName": "IPTV Player",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "node-mpv": "^1.5.0"
  }
}
